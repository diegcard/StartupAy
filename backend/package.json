{
  "name": "tickets-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d data-source.ts",
    "db:migrate:gen": "typeorm-ts-node-commonjs migration:generate src/migrations/Migration -d data-source.ts",
    "db:migrate:revert": "typeorm-ts-node-commonjs migration:revert -d data-source.ts",
    "db:studio": "npx prisma studio",
    "db:seed": "ts-node src/seeds/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^22.9.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.10.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.3"
  }
}
